# SPA fallback — Apache & LiteSpeed (shared hosting).
# Deep links (/verify-email, /checkout/return, /profile, …) must serve index.html or you get a server 404.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^index\.html$ - [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # QSA keeps ?token=… and ?session_id=… on the request for React Router.
  RewriteRule . /index.html [L,QSA]
</IfModule>
