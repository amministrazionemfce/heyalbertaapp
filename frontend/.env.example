# API origin only (no /api suffix). Local dev: use http://localhost:8000 (not https://localhost).
# Production build: set to your deployed API, e.g. https://xxx.up.railway.app
# With `npm start`, if this points at a remote host but you open the app on localhost, api.js uses localhost:8000 anyway.
# Hostname-only values are auto-prefixed with https:// at build time (except localhost → http).
REACT_APP_BACKEND_URL=http://localhost:8000
# Maps Embed API; must start with AIzaSy (not AlzaSy). Restrict key to your domains in Google Cloud Console.
REACT_APP_GOOGLE_MAPS_API_KEY=
# Stripe publishable key only (pk_test_... / pk_live_...). Never put API secrets or GitHub tokens here.
REACT_APP_STRIPE_PUBLISHABLE_KEY=
